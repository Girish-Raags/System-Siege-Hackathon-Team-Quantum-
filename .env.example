# Copy this file to .env and fill in real values before deploying.

# --- Storage ---
# Local dev default (SQLite file). For production, point this at a
# managed Postgres instance instead, e.g.:
# DATABASE_URL=postgresql://user:password@host:5432/webguard
DATABASE_URL=sqlite:///./webguard.db

# --- Auth ---
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Bootstrap admin account (created automatically on first startup) ---
BOOTSTRAP_ADMIN_EMAIL=admin@webguard.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# --- Monitoring ---
DEFAULT_CHECK_INTERVAL_SECONDS=300
MIN_CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=10
ANOMALY_THRESHOLD=18.0

# --- AI-driven risk analysis (optional) ---
# If left blank, WebGuard automatically uses transparent rule-based risk
# scoring instead — the platform is fully functional either way.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- CORS ---
CORS_ORIGINS=*
